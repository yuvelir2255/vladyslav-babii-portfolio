# Contact form → Telegram. Copy to .env.local and fill with real values.
# Bot token from @BotFather (/newbot). Chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Canonical site origin for metadata/OG/sitemap (no trailing slash).
# Leave empty in dev (falls back to localhost) and on Vercel (uses the project's
# production URL). Set it once a custom domain is live, e.g. https://example.com
NEXT_PUBLIC_SITE_URL=
